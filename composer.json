{
	"name": "nextcloud/absence",
	"description": "Vacation approval workflow for Nextcloud",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "Frank Karlitschek",
			"email": "frank@nextcloud.com"
		}
	],
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"nextcloud/coding-standard": "^1.3",
		"nextcloud/ocp": "dev-master",
		"phpunit/phpunit": "^9.6",
		"vimeo/psalm": "^5.26"
	},
	"autoload": {
		"psr-4": {
			"OCA\\Absence\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\Absence\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm --no-cache",
		"test:unit": "phpunit --config tests/phpunit.xml"
	},
	"config": {
		"allow-plugins": {
			"php-http/discovery": true
		},
		"sort-packages": true
	}
}
